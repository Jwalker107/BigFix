<?xml version="1.0" encoding="UTF-8"?>
<BES xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="BES.xsd">
	<Fixlet>
		<Title>Example Parameterized Fixlet with SecureParameters to Run As User with Admin Privilege</Title>
		<Description><![CDATA[<!-- Generic Parameterized Fixlet -->
This fixlet allows running an arbitrary command, as an arbitrary user.<br>
<H3>The command runs with Elevated Privileges, even if the user is not a member of the Administrators group</H3><br>
Supply the username, password, and command line to run below.<br>
The command line should include the complete `cmd.exe /c` to run Windows commands.<br>
<br>
Example:<br>
cmd.exe /c "echo Hello World from %USERNAME% > %WINDIR%\message.txt 2>&1"
<p>
		<!-- The validation logic uses two custom optional attributes on input fields --><!-- required="true" indicates the value must be supplied --><!-- secure="true" indicates the value should be sent as a Secure Parameter -->
<P style="MARGIN-RIGHT: 0px" dir=ltr><LABEL for=parameters><STRONG><FONT color=#008000 size=3>Customization Options</FONT></STRONG></LABEL> </P>
<TABLE>
<TBODY>
<TR>
<TH></TH>
<TR>
  <TD>username</TD>
  <TD><INPUT id=username name=username required="true"></TD>
</TR>
<TR>
  <TD>Command Line to run (including cmd.exe /c if needed)</TD>
  <TD><INPUT id=commandline name=commandline size=80></TD>
</TR>
<TR>
  <TD>Secure 'action override password'</TD>
  <TD><INPUT id='action override password' type=password name='action override password' required="true" secure="true"></TD>
</TR>
</TBODY>
</TABLE>
<!-- for testing in browser outside of console --><!-- <button id="submit" onclick=takeAction()>Click Me</button> --><script>
 
 document.body.ontakeaction = function() { return takeAction(); }
 
 function takeAction() {
 	var block_action=false; parameters={}; secureparameters={};
	var secure=false; input_list=document.body.getElementsByTagName("input");
	for (i=0; i < input_list.length; i++) {
        if (toBool(input_list[i].getAttribute("required")) && trim(input_list[i].value)=="") {
            alert(input_list[i].name + " is required"); block_action=true; 
			return false; } 
		
        // if *any* Secure Parameter is defined, we must send using TakeSecureFixletAction
		if ( toBool(input_list[i].getAttribute("secure"))  || input_list[i].getAttribute("type")=="password" ) { secureparameters[input_list[i].name]=input_list[i].value; secure=true;
			} else { parameters[input_list[i].name]=input_list[i].value;
			}
		
	}
	if (toBool(secure)) {
		TakeSecureFixletAction( Relevance('id of current fixlet'), Relevance('id of current bes site'), "Action1", parameters, secureparameters );
		} else {
		TakeFixletAction( Relevance('id of current fixlet'), Relevance('id of current bes site'), "Action1", parameters );
		}
	return false;
}

function trim (str) {
    return str.replace(/^\s\s*/, '').replace(/\s\s*$/, '');
}

function toBool(value) {
  if ( !value ) { return false; }

  switch(value.toString().toLowerCase()) { 
    case "true": 
    case "1": 
    case "on": 
    case "yes": 
      return true; 
    default: 
      return false; 
  } 
}

</script> ]]></Description>
		<Relevance>if exists property "in proxy agent context" then not in proxy agent context else true</Relevance>
		<Relevance><![CDATA[version of client >= "9.0"]]></Relevance>
		<Category>Example</Category>
		<DownloadSize>0</DownloadSize>
		<Source>Internal</Source>
		<SourceID>Jason Walker</SourceID>
		<SourceReleaseDate>2022-07-07</SourceReleaseDate>
		<SourceSeverity></SourceSeverity>
		<CVENames></CVENames>
		<SANSID></SANSID>
		<MIMEField>
			<Name>x-bfsync-source-actionsite</Name>
			<Value>http://BES-Dev-Root:52311/cgi-bin/bfgather.exe/actionsite</Value>
		</MIMEField>
		<MIMEField>
			<Name>x-bfsync-source-modification-time</Name>
			<Value>Tue, 15 Nov 2022 16:21:34 +0000</Value>
		</MIMEField>
		<MIMEField>
			<Name>x-bfsync-source-id</Name>
			<Value>7431</Value>
		</MIMEField>
		<MIMEField>
			<Name>x-fixlet-modification-time</Name>
			<Value>Thu, 02 Feb 2023 14:58:03 +0000</Value>
		</MIMEField>
		<Domain>BESC</Domain>
		<DefaultAction ID="Action1">
			<Description>
				<PreLink></PreLink>
				<Link>Take Action </Link>
				<PostLink></PostLink>
			</Description>
			<ActionScript MIMEType="application/x-Fixlet-Windows-Shell">

action parameter query "username" with description "username"
action parameter query "commandline" with description "commandline to run, including cmd.exe /c if needed"

// Secure Parameters should not be queried, they have to be encoded in javascript before here.
// action parameter query "action override password" with description "action override password"


override wait
runas=localuser
user={parameter "username" of action}
password=required
asadmin=true
wait {parameter "commandline" of action}
</ActionScript>
			<SuccessCriteria Option="RunToCompletion"></SuccessCriteria>
		</DefaultAction>
	</Fixlet>
</BES>
